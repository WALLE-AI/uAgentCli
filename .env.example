# Anthropic（主 provider）
ANTHROPIC_API_KEY=
# 留空则使用官方默认 https://api.anthropic.com；自建/代理端点在此覆盖。
ANTHROPIC_BASE_URL=

# OpenAI 兼容族
OPENAI_API_KEY=
# 留空则使用官方默认 https://api.openai.com/v1。
OPENAI_BASE_URL=

DEEPSEEK_API_KEY=
QWEN_API_KEY=
OPENROUTER_API_KEY=

# uAgentCli 运行目录（留空则使用默认 ~/.uagent）
UAGENT_HOME=

# 本次会话使用的模型 id（留空默认 claude-sonnet-5）。按 selectModelVariant()
# 的关键字匹配路由到 anthropic/openai-compatible provider。
UAGENT_MODEL=
