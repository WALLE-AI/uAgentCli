{
  "name": "uagentcli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "uAgentCli 多智能体平台",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "uagentcli": "./src/cli/main.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "tsx --env-file-if-exists=.env src/cli/main.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "better-sqlite3": "^11.7.0",
    "https-proxy-agent": "^9.1.0",
    "openai": "^4.77.0",
    "yaml": "^2.9.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "memfs": "^4.15.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "allowScripts": {
    "better-sqlite3@11.10.0": true,
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true
  }
}
